# Password di accesso al gestionale (CAMBIALA!)
APP_PASSWORD=cambia-questa-password

# Chiave segreta per i cookie di sessione (una stringa lunga e casuale)
SESSION_SECRET=inserisci-una-stringa-lunga-e-casuale

# Cartella dove salvare il database.
# In locale lascia ./data. Su Railway usa il percorso del volume, es. /data
DATA_DIR=./data

# Porta (Railway la imposta in automatico, in locale usa 3000)
PORT=3000
